{
   "expo": {
      "name": "skpceditor",
      "slug": "mobile",
      "version": "1.0.0",
      "orientation": "portrait",
      "icon": "./assets/images/icon.png",
      "scheme": "mobile",
      "userInterfaceStyle": "dark",
      "newArchEnabled": true,
      "splash": {
         "image": "./assets/images/icon.png",
         "resizeMode": "contain",
         "backgroundColor": "#0f0f13"
      },
      "ios": {
         "supportsTablet": false
      },
      "android": {
         "package": "com.skpceditor.assistente",
         "versionCode": 1,
         "adaptiveIcon": {
            "foregroundImage": "./assets/images/icon.png",
            "backgroundColor": "#0d1117"
         }
      },
      "web": {
         "favicon": "./assets/images/icon.png"
      },
      "plugins": [
         [
            "expo-router",
            {
               "origin": "https://replit.com/"
            }
         ],
         "expo-font",
         "expo-web-browser",
         "expo-av"
      ],
      "experiments": {
         "typedRoutes": true,
         "reactCompiler": true
      }
   }
}